<!DOCTYPE html>
<html>
<head>
  <title>Game Rental Website</title>

  <style>

    body{
      margin:0;
      font-family: Arial, sans-serif;
      background-color:#f4f4f4;
    }


    nav{
      background-color:#222;
      color:white;
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:15px 30px;
    }

    nav h1{
      color:#ffcc00;
    }

    nav ul{
      list-style:none;
      display:flex;
      gap:20px;
    }

    nav ul li{
      cursor:pointer;
    }

    nav ul li:hover{
      color:#ffcc00;
    }

    .hero{
      background:linear-gradient(to right,#ffcc00,#ffe680);
      text-align:center;
      padding:70px 20px;
    }

    .hero h2{
      font-size:50px;
      color:#222;
    }

    .hero p{
      max-width:700px;
      margin:auto;
      font-size:18px;
      line-height:1.6;
      color:#333;
    }

    .hero button{
      margin-top:20px;
      padding:12px 25px;
      background-color:#222;
      color:white;
      border:none;
      border-radius:5px;
      cursor:pointer;
    }

    .hero button:hover{
      background-color:#444;
    }

    .search-box{
      text-align:center;
      margin-top:30px;
    }

    .search-box input{
      padding:10px;
      width:250px;
      border:1px solid #999;
      border-radius:5px;
    }

    .search-box button{
      padding:10px 15px;
      background-color:#222;
      color:white;
      border:none;
      border-radius:5px;
      cursor:pointer;
    }

    .genres{
      text-align:center;
      margin-top:40px;
    }

    .genres button{
      margin:5px;
      padding:10px 15px;
      border:none;
      background-color:#222;
      color:white;
      border-radius:5px;
      cursor:pointer;
    }

    .genres button:hover{
      background-color:#ffcc00;
      color:black;
    }

    .games-section{
      padding:40px;
    }

    .games-section h2{
      text-align:center;
      margin-bottom:30px;
    }

    .games{
      display:flex;
      justify-content:center;
      flex-wrap:wrap;
      gap:25px;
    }

    .card{
      width:280px;
      background-color:white;
      border-radius:10px;
      overflow:hidden;
      box-shadow:0 2px 8px rgba(0,0,0,0.2);
      transition:0.3s;
    }

    .card:hover{
      transform:translateY(-5px);
    }

    .card img{
      width:100%;
      height:180px;
      object-fit:cover;
    }

    .card-content{
      padding:15px;
      text-align:center;
    }

    .card-content h3{
      margin:10px 0;
    }

    .price{
      color:green;
      font-weight:bold;
      margin:10px 0;
    }

    .card-content button{
      padding:10px 15px;
      background-color:#222;
      color:white;
      border:none;
      border-radius:5px;
      cursor:pointer;
    }

    .card-content button:hover{
      background-color:#ffcc00;
      color:black;
    }


    .features{
      display:flex;
      justify-content:center;
      gap:20px;
      flex-wrap:wrap;
      padding:30px;
    }

    .feature-box{
      width:250px;
      background-color:white;
      padding:20px;
      text-align:center;
      border-radius:10px;
      box-shadow:0 2px 5px rgba(0,0,0,0.2);
    }

    footer{
      background-color:#222;
      color:white;
      text-align:center;
      padding:15px;
      margin-top:30px;
    }

  </style>
</head>

<body>

  <nav>

    <h1>GameZone</h1>

    <ul>
      <li>Home</li>
      <li>Games</li>
      <li>Categories</li>
      <li>Contact</li>
    </ul>

  </nav>

  <!-- Hero Section -->

  <div class="hero">

    <h2>Affordable Game Rentals</h2>

    <p>
      Rent expensive games at affordable prices based on duration of use.
      Browse action, racing, adventure and multiplayer games easily.
    </p>

    <button>Explore Games</button>

    <div class="search-box">

      <input type="text" placeholder="Search games...">

      <button>Search</button>

    </div>

  </div>

  <div class="genres">

    <button>Action</button>
    <button>Adventure</button>
    <button>Racing</button>
    <button>Sports</button>
    <button>Horror</button>

  </div>

  <div class="games-section">

    <h2>Featured Games</h2>

    <div class="games">

      <div class="card">

        <img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?q=80&w=1200&auto=format&fit=crop">

        <div class="card-content">

          <h3>Cyber Drift</h3>

          <p>Exciting racing game with realistic graphics.</p>

          <div class="price">₹299 / Week</div>

          <button>Rent Now</button>

        </div>

      </div>

      <div class="card">

        <img src="https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=1200&auto=format&fit=crop">

        <div class="card-content">

          <h3>Shadow Arena</h3>

          <p>Popular action game with multiplayer battles.</p>

          <div class="price">₹399 / Week</div>

          <button>Rent Now</button>

        </div>

      </div>

      <div class="card">

        <img src="https://images.unsplash.com/photo-1493711662062-fa541adb3fc8?q=80&w=1200&auto=format&fit=crop">

        <div class="card-content">

          <h3>Galaxy Quest</h3>

          <p>Adventure game with missions and exploration.</p>

          <div class="price">₹349 / Week</div>

          <button>Rent Now</button>

        </div>

      </div>

    </div>

  </div>

  <div class="features">

    <div class="feature-box">

      <h3>Search Games</h3>

      <p>Users can quickly search games using the search option.</p>

    </div>

    <div class="feature-box">

      <h3>Genre Filters</h3>

      <p>Games can be filtered based on categories and interests.</p>

    </div>

    <div class="feature-box">

      <h3>Affordable Rentals</h3>

      <p>Enjoy premium games without purchasing expensive copies.</p>

    </div>

  </div>


  <footer>

    <p>GameZone - Game Rental Website Project</p>

  </footer>

</body>
</html>
